# Iizuka LinkedIn Network — 環境変数テンプレート
# このファイルを .env にコピーして値を入力してください
# .env は絶対にGitHubにコミットしないこと（.gitignoreで除外済み）

# e-Stat API（総務省統計局 / 無料）
# 取得先: https://www.e-stat.go.jp/api/
ESTAT_API_KEY=your_estat_api_key_here

# Anthropic（Claude）
# 取得先: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Slack
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL_ID=C08JMQ7L5GF

# Google Drive（レポート・コンテンツ保存先フォルダID）
GOOGLE_DRIVE_FOLDER_ID=1MF6IqgHDSIdcQdJB5dG7qgMpT_OLk2Dg

# Zapier（MCP経由で使用する場合）
# ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/xxxxxx/
